.tabs { display: flex; background: #fff; border-radius: 12rpx; margin-bottom: 20rpx; }
.tab { flex: 1; text-align: center; padding: 20rpx; font-size: 28rpx; color: #666; border-bottom: 4rpx solid transparent; }
.tab.active { color: #1890ff; border-bottom-color: #1890ff; font-weight: bold; }
.list-item { display: flex; align-items: center; background: #fff; padding: 24rpx; border-bottom: 1rpx solid #f0f0f0; border-radius: 12rpx; margin-bottom: 8rpx; }
.item-left { flex: 1; }
.vin-text { font-size: 28rpx; font-weight: bold; display: block; }
.sub-text { font-size: 24rpx; color: #999; display: block; margin-top: 4rpx; }
.arrow { color: #ccc; font-size: 32rpx; }
.activity-header { display: flex; align-items: center; margin-bottom: 8rpx; }
.activity-method { font-size: 24rpx; color: #666; margin-left: 12rpx; }
.activity-content { display: block; font-size: 26rpx; color: #333; margin-bottom: 8rpx; }
.activity-time { font-size: 22rpx; color: #999; }
.fab { position: fixed; right: 30rpx; bottom: 60rpx; background: #1890ff; color: #fff; padding: 20rpx 32rpx; border-radius: 40rpx; font-size: 28rpx; box-shadow: 0 4rpx 16rpx rgba(24,144,255,0.4); }
