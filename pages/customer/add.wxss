.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 24rpx;
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.label.required::before {
  content: '*';
  color: #e74c3c;
  margin-right: 6rpx;
}

.input {
  width: 100%;
  height: 72rpx;
  font-size: 28rpx;
  color: #333;
  padding: 0 20rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  height: 160rpx;
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 20rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.tip-box {
  display: flex;
  align-items: flex-start;
  background: #fff8e6;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 40rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #8c6d1f;
  line-height: 1.5;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1890ff, #096dd9);
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.btn-submit[loading] {
  opacity: 0.7;
}
