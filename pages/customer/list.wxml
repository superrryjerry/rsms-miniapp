<view class="search-bar"><input placeholder="搜索客户名称" bindconfirm="onSearch" value="{{keyword}}" /></view>
<view class="list-container">
  <view class="list-item" wx:for="{{list}}" wx:key="id" bindtap="goDetail" data-name="{{item.customer_name}}">
    <view class="item-left">
      <view class="name-row">
        <text class="name-text">{{item.customer_name}}</text>
        <text class="tag tag-mine" wx:if="{{item.is_mine}}">我的客户</text>
      </view>
      <text class="sub-text">服务经销商: {{item.service_dealers_summary || '-'}}</text>
    </view>
    <text class="arrow">></text>
  </view>
  <view class="empty" wx:if="{{!loading && list.length === 0}}">暂无数据</view>
  <view class="loading-tip" wx:if="{{loading}}">加载中...</view>
  <view class="loading-tip" wx:if="{{noMore && list.length > 0}}">没有更多了</view>
</view>
