<view class="search-bar">
  <input placeholder="搜索客户名称" bindconfirm="onSearch" value="{{keyword}}" />
</view>
<view class="list-container">
  <view class="list-item" wx:for="{{list}}" wx:key="id">
    <view class="item-left" bindtap="goDetail" data-name="{{item.customer_name}}">
      <view class="name-row">
        <text class="name-text">{{item.customer_name}}</text>
        <text class="tag-badge tag-{{item.my_tag || 'none'}}" wx:if="{{item.my_tag}}">{{item.my_tag === 'core' ? '核心' : item.my_tag === 'focus' ? '焦点' : item.my_tag === 'oasis' ? '绿洲' : item.my_tag === 'desert' ? '沙漠' : ''}}</text>
        <text class="tag-warning" wx:if="{{item.warning}}">⚠️</text>
      </view>
      <text class="sub-text">服务经销商: {{item.service_dealers_short}}</text>
    </view>
    <picker mode="selector" range="{{tagOptions}}" range-key="label" value="{{item.my_tag ? tagIndexMap[item.my_tag] : 0}}" bindchange="onTagChange" data-index="{{index}}" data-name="{{item.customer_name}}">
      <view class="tag-picker-btn">🏷️</view>
    </picker>
  </view>
  <view class="empty" wx:if="{{!loading && list.length === 0}}">暂无数据</view>
  <view class="loading-tip" wx:if="{{loading}}">加载中...</view>
  <view class="loading-tip" wx:if="{{noMore && list.length > 0}}">没有更多了</view>
</view>
<!-- 底部悬浮新增按钮 -->
<view class="fab-btn" bindtap="goAdd">
  <view class="fab-circle">
    <text class="fab-icon">+</text>
  </view>
</view>
