.list-container { padding-bottom: 20rpx; }
.list-item { display: flex; align-items: center; background: #fff; padding: 24rpx; border-bottom: 1rpx solid #f0f0f0; }
.item-left { flex: 1; }
.name-row { display: flex; align-items: center; margin-bottom: 8rpx; flex-wrap: wrap; }
.name-text { font-size: 30rpx; font-weight: bold; margin-right: 12rpx; }
.sub-text { display: block; font-size: 24rpx; color: #999; }
.arrow { color: #ccc; font-size: 32rpx; }
.loading-tip { text-align: center; padding: 20rpx; color: #999; font-size: 24rpx; }

/* 标签样式 */
.tag-badge { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 6rpx; color: #fff; margin-left: 8rpx; }
.tag-core { background-color: #52c41a; }
.tag-focus { background-color: #fa8c16; }
.tag-oasis { background-color: #fadb14; color: #333; }
.tag-desert { background-color: #f5222d; }
.tag-none { background-color: #d9d9d9; color: #666; }

/* 标签选择按钮 */
.tag-picker-btn { font-size: 40rpx; padding: 10rpx 16rpx; }

/* 新增客户按钮 */
.add-btn-wrap { padding: 16rpx 24rpx; }
.add-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #1890ff, #096dd9);
  color: #fff;
  font-size: 28rpx;
  border-radius: 36rpx;
  border: none;
  text-align: center;
}
