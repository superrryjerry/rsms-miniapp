.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.content-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
}

.section {
  margin-bottom: 48rpx;
}

.section:last-child {
  margin-bottom: 0;
}

.title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.heading {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-top: 24rpx;
  margin-bottom: 12rpx;
}

.desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  white-space: pre-wrap;
}
