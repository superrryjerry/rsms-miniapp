<view class="container">
  <view class="card profile-card">
    <view class="avatar">{{userInfo.name[0] || '?'}}</view>
    <view class="profile-info">
      <text class="name">{{userInfo.name}}</text>
      <text class="phone">{{userInfo.phone}}</text>
      <text class="dealer">经销商: {{userInfo.dealer_code || '-'}}</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goRequests">
      <text>我的申请</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goGuide">
      <text>快速上手</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goAbout">
      <text>关于我们</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goAgreement">
      <text>用户协议与隐私政策</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="onLogout">
      <text class="logout-text">退出登录</text>
    </view>
  </view>
</view>
