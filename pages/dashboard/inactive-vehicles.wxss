.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #ff4d4f 0%, #cf1322 100%);
  color: #fff;
}

.header-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: bold;
}

.header-desc {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 12rpx;
  text-align: center;
}

.list-item {
  padding: 24rpx 30rpx;
}

.item-main {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-vin {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.item-plate {
  font-size: 24rpx;
  color: #1890ff;
  background: #e6f7ff;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
}

.item-info {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.item-label {
  font-size: 26rpx;
  color: #999;
}

.item-value {
  font-size: 26rpx;
  color: #333;
}

.item-value.warning {
  color: #fa8c16;
}

.item-value.danger {
  color: #ff4d4f;
  font-weight: 500;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
