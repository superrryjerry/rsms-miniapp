.filter-bar { background: #fff; padding: 20rpx 24rpx; font-size: 28rpx; color: #1890ff; margin-bottom: 16rpx; }
.lead-card { margin: 0 20rpx 16rpx; }
.lead-header { display: flex; align-items: center; margin-bottom: 12rpx; }
.lead-type { font-size: 26rpx; color: #666; margin-left: 12rpx; flex: 1; }
.action-btn { font-size: 24rpx; padding: 8rpx 20rpx; background: #1890ff; color: #fff; border-radius: 8rpx; border: none; }
.tag { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 6rpx; }
.tag.pending { background: #fff7e6; color: #fa8c16; }
.tag.warning { background: #e6f7ff; color: #1890ff; }
.tag.done { background: #f6ffed; color: #52c41a; }
.tag.ignored { background: #f5f5f5; color: #999; }
.info-row { display: flex; justify-content: space-between; padding: 8rpx 0; font-size: 26rpx; }
.info-label { color: #999; }
.info-value { color: #333; }
.loading-tip { text-align: center; padding: 20rpx; color: #999; font-size: 24rpx; }
.empty { text-align: center; padding: 60rpx 0; color: #999; font-size: 28rpx; }
