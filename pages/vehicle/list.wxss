.list-container { padding-bottom: 20rpx; }
.list-item { display: flex; align-items: center; background: #fff; padding: 24rpx; border-bottom: 1rpx solid #f0f0f0; }
.item-left { flex: 1; }
.vin-row { display: flex; align-items: center; margin-bottom: 8rpx; }
.vin-text { font-size: 30rpx; font-weight: bold; margin-right: 12rpx; }
.sub-text { display: block; font-size: 24rpx; color: #999; margin-top: 4rpx; }
.arrow { color: #ccc; font-size: 32rpx; }
.loading-tip { text-align: center; padding: 20rpx; color: #999; font-size: 24rpx; }
.tag { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 6rpx; margin-left: 8rpx; }
.tag-mine { background: #e6f7ff; color: #1890ff; }
.tag-warning { background: #fff2e8; color: #ff4d4f; font-size: 24rpx; }
.empty { text-align: center; padding: 100rpx 0; color: #999; font-size: 28rpx; }
