<view class="search-bar">
  <input placeholder="搜索VIN/车牌/客户/车型" bindconfirm="onSearch" value="{{keyword}}" />
</view>
<view class="list-container">
  <view class="list-item" wx:for="{{list}}" wx:key="vin" bindtap="goDetail" data-vin="{{item.vin}}">
    <view class="item-left">
      <view class="vin-row">
        <text class="vin-text">{{item.vin}}</text>
        <text class="tag tag-mine" wx:if="{{item.is_mine}}">我的车辆</text>
      </view>
      <text class="sub-text">{{item.customer_name || '未知客户'}} | {{item.model || '-'}}</text>
      <text class="sub-text">归属: {{item.service_dealer}}</text>
    </view>
    <text class="arrow">></text>
  </view>
  <view class="empty" wx:if="{{!loading && list.length === 0}}">暂无数据</view>
  <view class="loading-tip" wx:if="{{loading}}">加载中...</view>
  <view class="loading-tip" wx:if="{{noMore && list.length > 0}}">没有更多了</view>
</view>
