<view class="login-page">
  <view class="logo-area">
    <text class="title">RSMS</text>
    <text class="subtitle">经销商CRM管理系统</text>
  </view>
  <view class="form">
    <input class="input" placeholder="手机号" type="number" maxlength="11" bindinput="onInput" data-field="phone" />
    <input class="input" placeholder="密码" password bindinput="onInput" data-field="password" />
    <button class="btn-login" bindtap="onLogin">登 录</button>
  </view>
</view>
