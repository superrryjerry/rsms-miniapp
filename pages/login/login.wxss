.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1890ff, #096dd9);
  padding: 40rpx;
}
.logo-area { text-align: center; margin-bottom: 80rpx; }
.title { display: block; font-size: 72rpx; color: #fff; font-weight: bold; }
.subtitle { display: block; font-size: 28rpx; color: rgba(255,255,255,0.8); margin-top: 16rpx; }
.form { width: 100%; }
.input {
  background: rgba(255,255,255,0.95);
  border-radius: 12rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  font-size: 30rpx;
}
.btn-login {
  background: #fff;
  color: #1890ff;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 20rpx;
}
