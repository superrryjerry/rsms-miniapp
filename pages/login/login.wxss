.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
}

.logo-area { 
  text-align: center; 
  margin-bottom: 80rpx; 
}

.logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.title { 
  display: block; 
  font-size: 72rpx; 
  color: #fff; 
  font-weight: bold;
  letter-spacing: 4rpx;
}

.subtitle { 
  display: block; 
  font-size: 28rpx; 
  color: rgba(255,255,255,0.9); 
  margin-top: 16rpx;
}

.form { 
  width: 100%; 
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.95);
  border-radius: 12rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.input-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
  opacity: 0.6;
}

.input {
  flex: 1;
  padding: 28rpx 0;
  font-size: 30rpx;
}

.btn-login {
  background: #fff;
  color: #667eea;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}
