.welcome { padding: 40rpx 32rpx; }
.greeting { display: block; font-size: 36rpx; font-weight: bold; color: #333; }
.dealer { display: block; font-size: 24rpx; color: #999; margin-top: 8rpx; }
.lead-badge {
  margin-top: 16rpx;
  background: #fff1f0;
  color: #f5222d;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  display: inline-block;
  font-size: 24rpx;
}
.section-title { font-size: 30rpx; font-weight: bold; margin: 24rpx 0 16rpx; color: #333; }
.grid {
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 0;
}
.grid-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
}
.grid-icon { font-size: 48rpx; margin-bottom: 8rpx; }
.grid-name { font-size: 24rpx; color: #666; }
