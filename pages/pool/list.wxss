.list-container { padding-bottom: 20rpx; }
.list-item { display: flex; align-items: center; background: #fff; padding: 24rpx; border-bottom: 1rpx solid #f0f0f0; }
.item-left { flex: 1; }
.vin-text { font-size: 30rpx; font-weight: bold; display: block; margin-bottom: 4rpx; }
.sub-text { display: block; font-size: 24rpx; color: #999; margin-top: 4rpx; }
.claim-btn { background: #1890ff; color: #fff; font-size: 24rpx; padding: 10rpx 24rpx; border-radius: 8rpx; line-height: 1.5; }
.loading-tip { text-align: center; padding: 20rpx; color: #999; font-size: 24rpx; }
