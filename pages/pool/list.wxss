.list-container { padding: 16rpx 0 40rpx; }
.list-item { display: flex; align-items: center; background: #fff; padding: 28rpx 24rpx; margin: 20rpx 24rpx; border-radius: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08); }
.item-left { flex: 1; }
.vin-text { font-size: 30rpx; font-weight: bold; display: block; margin-bottom: 6rpx; }
.sub-text { display: block; font-size: 24rpx; color: #999; margin-top: 6rpx; }
.claim-btn { background: #1890ff; color: #fff; font-size: 24rpx; padding: 12rpx 28rpx; border-radius: 28rpx; line-height: 1.5; white-space: nowrap; }
.loading-tip { text-align: center; padding: 20rpx; color: #999; font-size: 24rpx; }
