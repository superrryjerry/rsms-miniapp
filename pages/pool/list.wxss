.list-container { padding-bottom: 20rpx; }
.list-item { display: flex; align-items: center; background: #fff; padding: 24rpx; margin: 16rpx 24rpx; border-radius: 12rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.item-left { flex: 1; }
.vin-text { font-size: 30rpx; font-weight: bold; display: block; margin-bottom: 4rpx; }
.sub-text { display: block; font-size: 24rpx; color: #999; margin-top: 4rpx; }
.claim-btn { background: #1890ff; color: #fff; font-size: 24rpx; padding: 10rpx 24rpx; border-radius: 24rpx; line-height: 1.5; white-space: nowrap; }
.loading-tip { text-align: center; padding: 20rpx; color: #999; font-size: 24rpx; }
