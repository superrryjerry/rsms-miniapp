<view class="search-bar"><input placeholder="搜索VIN/车牌/客户/车型" bindconfirm="onSearch" value="{{keyword}}" /></view>
<view class="list-container">
  <view class="list-item" wx:for="{{list}}" wx:key="vin">
    <view class="item-left" bindtap="goDetail" data-vin="{{item.vin}}">
      <text class="vin-text">{{item.vin}}</text>
      <text class="sub-text">{{item.customer_name || '未知客户'}} | {{item.model || '-'}}</text>
      <text class="sub-text">车牌: {{item.license_plate || '-'}}</text>
    </view>
    <view class="claim-btn" catchtap="onClaim" data-vin="{{item.vin}}">认领</view>
  </view>
  <view class="empty" wx:if="{{!loading && list.length === 0}}">暂无数据</view>
  <view class="loading-tip" wx:if="{{loading}}">加载中...</view>
  <view class="loading-tip" wx:if="{{noMore && list.length > 0}}">没有更多了</view>
</view>
