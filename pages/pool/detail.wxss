.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.empty-tip {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

.history-item {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #e8e8e8;
}

.history-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.service-stat {
  background: #f0f7ff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}

.service-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.service-info {
  font-size: 24rpx;
  color: #666;
}

.action-area {
  margin-top: 30rpx;
  padding: 0 20rpx;
}

.btn {
  margin-bottom: 16rpx;
}
