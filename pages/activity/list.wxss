.activity-header { display: flex; align-items: center; margin-bottom: 8rpx; }
.method { font-size: 24rpx; color: #666; margin-left: 12rpx; }
.customer-name { display: block; font-size: 30rpx; font-weight: bold; margin-bottom: 8rpx; }
.activity-preview { display: block; font-size: 26rpx; color: #666; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.time { display: block; font-size: 22rpx; color: #999; margin-top: 8rpx; }
.fab { position: fixed; right: 30rpx; bottom: 60rpx; background: #1890ff; color: #fff; padding: 20rpx 32rpx; border-radius: 40rpx; font-size: 28rpx; box-shadow: 0 4rpx 16rpx rgba(24,144,255,0.4); }
.loading-tip { text-align: center; padding: 20rpx; color: #999; font-size: 24rpx; }
