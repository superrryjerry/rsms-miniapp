/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333;
}
.container {
  padding: 20rpx;
}
.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
}
.tag-mine { background: #e6f7ff; color: #1890ff; }
.tag-draft { background: #fff7e6; color: #fa8c16; }
.tag-done { background: #f6ffed; color: #52c41a; }
.tag-warning { background: #fff7e6; color: #fa8c16; }
.tag-expired { background: #fff1f0; color: #f5222d; }
.tag-pending { background: #e6f7ff; color: #1890ff; }
.btn {
  display: block;
  text-align: center;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  margin-top: 20rpx;
}
.btn-primary { background: #1890ff; color: #fff; }
.btn-danger { background: #f5222d; color: #fff; }
.btn-default { background: #f0f0f0; color: #333; }
.search-bar {
  display: flex;
  padding: 16rpx 20rpx;
  background: #fff;
}
.search-bar input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 12rpx 20rpx;
  font-size: 28rpx;
}
.empty {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
}
.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.info-row {
  display: flex;
  padding: 12rpx 0;
  font-size: 26rpx;
}
.info-label {
  color: #999;
  width: 160rpx;
  flex-shrink: 0;
}
.info-value {
  flex: 1;
  color: #333;
}
