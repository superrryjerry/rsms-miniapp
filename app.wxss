/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333;
}

.container {
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.tag {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
  font-weight: 500;
}

.tag-mine { background: #e6f7ff; color: #1890ff; }
.tag-draft { background: #fff7e6; color: #fa8c16; }
.tag-done { background: #f6ffed; color: #52c41a; }
.tag-warning { background: #fff7e6; color: #fa8c16; }
.tag-expired { background: #fff1f0; color: #f5222d; }
.tag-pending { background: #e6f7ff; color: #1890ff; }

.btn {
  display: block;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-top: 20rpx;
  font-weight: 500;
  transition: all 0.3s;
}

.btn:active {
  opacity: 0.8;
}

.btn-primary { 
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.btn-danger { 
  background: #f5222d; 
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(245, 34, 45, 0.3);
}

.btn-default { 
  background: #f0f0f0; 
  color: #333;
}

.search-bar {
  display: flex;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx 16rpx 0 0;
}

.search-bar input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.3;
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s;
}

.list-item:active {
  background: #f9f9f9;
}

.list-item:last-child {
  border-bottom: none;
}

.info-row {
  display: flex;
  padding: 14rpx 0;
  font-size: 26rpx;
}

.info-label {
  color: #999;
  width: 180rpx;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  color: #333;
  font-weight: 500;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 下拉刷新提示 */
.refresh-tip {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 24rpx;
}
